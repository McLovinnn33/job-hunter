# ---------------------------------------------------------------
# Job Hunter — premenné prostredia (VZOR)
#
# Postup: skopírujte tento súbor ako .env.local a doplňte hodnoty.
# .env.local je v .gitignore — skutočné kľúče NIKDY nepatria do Gitu
# (SECURITY_GDPR.md pravidlo S2).
#
# Kde hodnoty nájdete: Supabase dashboard → váš projekt →
# Project Settings → API (resp. API Keys).
# ---------------------------------------------------------------

# URL vášho Supabase projektu (vyzerá ako https://xxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Verejný kľúč "anon public" (novšie projekty: "publishable" kľúč, začína sb_publishable_...)
# Tento kľúč JE bezpečný pre prehliadač — chránia ho RLS politiky (pravidlo S3).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Serverový "secret" kľúč (od M5 — scraper zapisuje do service tabuliek).
# Nájdete ho: Project Settings → API Keys → sekcia "Secret keys" (sb_secret_...).
# ⚠️ Tento kľúč obchádza všetky bezpečnostné pravidlá databázy — beží LEN na
# serveri, NIKDY sa nedostane do prehliadača (kód to vynucuje) ani do Gitu.
SUPABASE_SECRET_KEY=

# Anthropic API kľúč (od M3 — onboarding chat). console.anthropic.com →
# API Keys → Create Key. ⚠️ Reálny spendable secret — server-side only.
ANTHROPIC_API_KEY=
